rules_version = '2';

// Каркас Security Rules — принцип «default deny».
// Всё закрыто по умолчанию; правила для users/profiles открываются в шаге 8,
// остальные коллекции — точечно по мере фич в Сессии 2.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
